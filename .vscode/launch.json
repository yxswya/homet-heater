{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Bun: Debug server.ts",
      "program": "${workspaceFolder}/server.ts",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--inspect-brk"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Bun: Run server.ts",
      "program": "${workspaceFolder}/server.ts",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run"],
      "console": "integratedTerminal"
    }
  ]
}